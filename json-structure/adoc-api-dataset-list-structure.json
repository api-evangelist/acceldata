{
  "$schema": "https://json-structure.org/meta/extended/v0/#",
  "$id": "https://acceldata.io/structures/adoc-api-dataset-list.json",
  "title": "DatasetList",
  "type": "object",
  "description": "Paginated list of datasets",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "$ref": "dataset.json"
      }
    },
    "total": {
      "type": "integer"
    },
    "page": {
      "type": "integer"
    },
    "limit": {
      "type": "integer"
    }
  }
}